        "%%writefile hello_world.c\n",
        "#include <stdio.h>\n",
        "int main()\n",
        "{\n",
        "    int a, b, c;\n",
        "    printf(\"Enter the number: \");\n",
        "    scanf(\"%d\", &a);\n",
        "    int *p = &c;\n",
        "    printf(\"\\n========MENU=========\\n\");\n",
        "    printf(\"1.Addition: \\n\");\n",
        "    printf(\"2.Subtraction: \\n\");\n",
        "    printf(\"3.Multiplation: \\n\");\n",
        "    printf(\"4.Division: \\n\");\n",
        "    printf(\"5.Reminder: \\n\");\n",
        "    printf(\"Enter the number 1 to 5\\n\");\n",
        "    scanf(\"%d\", &b);\n",
        "    switch(b)\n",
        "    {\n",
        "        case 1:\n",
        "            c = a+b;\n",
        "            printf(\"Addition: %d\\n\", *p);\n",
        "            break;\n",
        "        case 2:\n",
        "            c = a-b;\n",
        "            printf(\"Subtraction: %d\\n\", *p);\n",
        "            break;\n",
        "        case 3:\n",
        "            c = a*b;\n",
        "            printf(\"Multiplation: %d\\n\", *p);\n",
        "            break;\n",
        "        case 4:\n",
        "            c = a/b;\n",
        "            printf(\"Division: %d\\n\", *p);\n",
        "            break;\n",
        "        case 5:\n",
        "            c = a%b;\n",
        "            printf(\"Reminder: %d\\n\", *p);\n",
        "            break;\n",
        "        default:\n",
        "            printf(\"Invalid Value\");\n",
        "    }\n",
        "    return 0;\n",
        "}"
      ]
